# ┌─────────────────────────────────────────────────────────┐
# │  Shelly Manager — Konfiguration                         │
# │  Kopiere diese Datei als ".env" und passe sie an.       │
# └─────────────────────────────────────────────────────────┘

# Port auf dem der Manager erreichbar ist
HOST_PORT=8095

# Pfad zur Datenbank (SQLite) — wird als Volume gemountet
APP_DB_PATH=./data

# Sicherheit: langen zufälligen String eingeben
# Tipp: openssl rand -hex 32
SECRET_KEY=hier-einen-langen-zufaelligen-string-eintragen

# Optional: Admin-Passwort per Env-Var setzen (überspringt den Setup-Wizard)
# Wenn leer gelassen → Setup-Wizard beim ersten Start
# ADMIN_PASSWORD=mein-sicheres-passwort

# Flask Modus (production lassen)
FLASK_ENV=production
